  "custom/window": {
    "format": "{text}",
    "return-type": "json",
    "exec": "/home/restart/.config/waybar/scripts/hypr-waybar-stream window",
    "restart-interval": 1,
    "max-length": 80,
    "tooltip": true
  },
  "custom/icon": {
    "format": "<span ><span color=\"#d8a657\"></span>{}</span> ",
    "exec": "echo []=",
    "interval": "once",
    "signal": 8
  },
  "custom/screen-timeout": {
    "format": "{}",
    "return-type": "json",
    "exec": "/home/restart/.config/hypr/scripts/screen-timeout-toggle status",
    "on-click": "/home/restart/.config/hypr/scripts/screen-timeout-toggle toggle",
    "interval": 5,
    "signal": 9
  },
  "custom/low-power": {
    "format": "{}",
    "return-type": "json",
    "exec": "/home/restart/.config/hypr/scripts/low-power-toggle status",
    "on-click": "/home/restart/.config/hypr/scripts/low-power-toggle toggle",
    "interval": 5,
    "signal": 10
  },
  "custom/cpu-temp": {
    "format": "{}",
    "return-type": "json",
    "exec": "/home/restart/.config/waybar/scripts/cpu-temp",
    "interval": 3
  },
  "pulseaudio": {
    "format": "{volume}% {icon}  |",
    "format-muted": "muted 󰝟  |",
    "format-icons": {
      "default": ["", "", ""]
    },
    "scroll-step": 5,
    "on-click": "sh -c '/home/restart/.config/waybar/scripts/audio-menu >/tmp/waybar-audio-menu.log 2>&1 &'",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "tooltip-format": "{desc}\nLeft click: open/close audio menu\nRight click: mute"
  },
  "network": {
    "format-wifi": "{signalStrength}%   |",
    "format-ethernet": "󰈀  |",
    "format-disconnected": "󰤮  |",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
    "tooltip-format-ethernet": "Ethernet\n{ipaddr}",
    "tooltip-format-disconnected": "Disconnected"
  },
  "battery": {
	"bat": "BAT1",
	"interval": 15,
	"states": {
		"ac": 100,
		"warning": 30,
		"critical": 15
	},
	"events": {
		"on-charging-ac": "/home/restart/.config/swayosd/hypr-osd plugged-in-waybar",
			"on-discharging-ac": "/home/restart/.config/swayosd/hypr-osd unplugged-waybar",
		"on-discharging-warning": "/home/restart/.config/swayosd/hypr-osd battery-warning",
		"on-discharging-critical": "/home/restart/.config/swayosd/hypr-osd battery-critical",
		"on-charging-100": "/home/restart/.config/swayosd/hypr-osd battery-full"
	},
	"format": "{capacity}% {icon}",
		"format-discharging-ac": "{capacity}% {icon}",
	"format-warning": "{capacity}% 󰂃",
	"format-critical": "{capacity}% 󰁺",
	"format-charging": "{capacity}% 󰂄",
	"format-charging-ac": "{capacity}% 󰂄",
	"format-charging-warning": "{capacity}% 󰂄",
	"format-charging-critical": "{capacity}% 󰂄",
	"format-plugged": "{capacity}% 󰚥",
	"format-full": "{capacity}% 󰁹",
	"format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
	"tooltip-format": "{capacity}%\n{time}",
	"max-length": 25
},
  "custom/status-separator": {
    "format": "|",
    "interval": "once",
    "tooltip": false
  },
  "clock": {
    "format": "<span><span color=\"#ea6962\"></span>{:%a %b %d | %I:%M %p}</span>",
    "timezones": [
      "America/Montreal",
    ],
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "format": {
        "months": "<span color='#a6e3a1'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'>{}</span>",
        "weeks": "<span color='#74c7ec'><b>W{}</b></span>",
        "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
        "today": "<span background='#f38ba8' color='#1e1e2e'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-click": "tz_up",
      "on-click-right": "tz_down",
      "on-click-forward": "shift_up",
      "on-click-backward": "shift_down",
      "on-click-middle": "mode",
    }
  },
}
