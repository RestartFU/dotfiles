    "exec-on-event": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "tooltip": true
  },
  "custom/ws-4": {
    "format": "{text}",
    "return-type": "json",
    "exec": "/home/restart/.config/waybar/scripts/hypr-waybar-stream workspace 4",
    "restart-interval": 1,
    "on-click": "hyprctl dispatch workspace 4",
    "exec-on-event": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "tooltip": true
  },
  "custom/ws-5": {
    "format": "{text}",
    "return-type": "json",
    "exec": "/home/restart/.config/waybar/scripts/hypr-waybar-stream workspace 5",
    "restart-interval": 1,
    "on-click": "hyprctl dispatch workspace 5",
    "exec-on-event": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "tooltip": true
  },
  "custom/ws-6": {
    "format": "{text}",
    "return-type": "json",
    "exec": "/home/restart/.config/waybar/scripts/hypr-waybar-stream workspace 6",
    "restart-interval": 1,
    "on-click": "hyprctl dispatch workspace 6",
    "exec-on-event": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "tooltip": true
  },
  "custom/ws-7": {
    "format": "{text}",
    "return-type": "json",
    "exec": "/home/restart/.config/waybar/scripts/hypr-waybar-stream workspace 7",
    "restart-interval": 1,
    "on-click": "hyprctl dispatch workspace 7",
    "exec-on-event": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
