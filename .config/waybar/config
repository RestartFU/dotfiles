{
  // Set the bar to always be on top and at the top of the screen.
  "layer": "top",
  "position": "top",
  "height": 27,
  "reload_style_on_change": true,
  "modules-left": [
    "custom/ws-1",
    "custom/ws-2",
    "custom/ws-3",
    "custom/ws-4",
    "custom/ws-5",
    "custom/ws-6",
    "custom/ws-7",
    "custom/ws-8",
    "custom/ws-9",
    "custom/icon",
    "custom/window",
  ],
  "modules-center": [],
  "modules-right": [
    "custom/screen-timeout",
    "custom/low-power",
    "custom/cpu-temp",
    "pulseaudio",
    "network",
    "battery",
    "custom/status-separator",
    "clock"
  ],
  "custom/ws-1": {
    "format": "{text}",
    "return-type": "json",
    "exec": "/home/restart/.config/waybar/scripts/hypr-waybar-stream workspace 1",
    "restart-interval": 1,
    "on-click": "hyprctl dispatch workspace 1",
    "exec-on-event": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "tooltip": true
  },
  "custom/ws-2": {
    "format": "{text}",
    "return-type": "json",
    "exec": "/home/restart/.config/waybar/scripts/hypr-waybar-stream workspace 2",
    "restart-interval": 1,
    "on-click": "hyprctl dispatch workspace 2",
    "exec-on-event": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "tooltip": true
  },
  "custom/ws-3": {
    "format": "{text}",
    "return-type": "json",
    "exec": "/home/restart/.config/waybar/scripts/hypr-waybar-stream workspace 3",
