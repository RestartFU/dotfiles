        "terminal.ansi.bright_white": "#eeeeee",
        "terminal.ansi.bright_yellow": "#cccc55",
        "terminal.ansi.cyan": "#00aaaa",
        "terminal.ansi.green": "#55aa55",
        "terminal.ansi.magenta": "#aa55aa",
        "terminal.ansi.red": "#cc5555",
        "terminal.ansi.white": "#bbbbbb",
        "terminal.ansi.yellow": "#aaaa55",
        "terminal.background": "#1c1c1c",
        "terminal.foreground": "#bbbbbb",
