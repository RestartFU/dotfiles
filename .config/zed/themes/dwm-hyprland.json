          },
          "label": {
            "color": "#eeeeee"
          },
          "number": {
            "color": "#eeeeee"
          },
          "operator": {
            "color": "#bbbbbb"
          },
          "property": {
            "color": "#bbbbbb"
          },
          "punctuation": {
            "color": "#bbbbbb"
          },
          "string": {
            "color": "#aaaa55"
          },
          "string.special": {
            "color": "#00aaaa"
          },
          "type": {
            "color": "#eeeeee"
          },
          "variable": {
            "color": "#bbbbbb"
