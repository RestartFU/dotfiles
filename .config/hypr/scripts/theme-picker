#!/usr/bin/env bash
set -euo pipefail

THEMES_DIR="$HOME/.config/hyprland/themes"
THEMES_FILE="$THEMES_DIR/themes.tsv"
HYPR_THEME_FILE="$THEMES_DIR/hypr.conf"
WAYBAR_THEME_FILE="$THEMES_DIR/waybar.css"
SWAYOSD_THEME_FILE="$THEMES_DIR/swayosd.css"
FUZZEL_CONF="$HOME/.config/fuzzel/fuzzel.ini"
ZED_THEME_FILE="$HOME/.config/zed/themes/dwm-hyprland.json"
SWAYOSD_CONFIG="$HOME/.config/swayosd/config.toml"
SWAYOSD_STYLE="$HOME/.config/swayosd/style.css"
LOCK_FILE="${XDG_RUNTIME_DIR:-/tmp}/hypr-theme-picker.pid"
PREVIEW_PICKER="$HOME/.config/hypr/scripts/theme-preview-picker"

usage() {
  printf 'usage: %s [--apply THEME|--preview THEME|--list]\n' "${0##*/}" >&2
}

theme_line() {
  local name=$1
  awk -F '\t' -v name="$name" '($0 !~ /^#/ && $1 == name) { print; found=1; exit } END { exit found ? 0 : 1 }' "$THEMES_FILE"
}

list_themes() {
  awk -F '\t' '$0 !~ /^#/ && NF >= 2 { printf "%-11s #%s  %s\n", $1, $2, $3 }' "$THEMES_FILE"
}

hex_to_rgb() {
  local hex=$1
  printf '%d %d %d\n' "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}


rewrite_waybar_style_color() {
  local hex=$1 tmp
  local style="$HOME/.config/waybar/style.css"
  [[ -f "$style" ]] || return 0
  tmp=$(mktemp)
  awk -v accent="@define-color col_cyan #${hex};" '
    /^@define-color col_cyan / { print accent; done=1; next }
    { print }
    END { if (!done) print accent }
  ' "$style" > "$tmp"
  cat "$tmp" > "$style"
  rm -f "$tmp"
}


rewrite_zed_theme_color() {
  local hex=$1 tmp tmp2 old suffix
  [[ -f "$ZED_THEME_FILE" ]] || return 0
  tmp=$(mktemp)
  cp "$ZED_THEME_FILE" "$tmp"
  while IFS=$'\t' read -r _ old _; do
    [[ -n "${old:-}" && "$old" != \#* ]] || continue
    for suffix in 88 66 ""; do
      tmp2=$(mktemp)
      sed "s/#${old}${suffix}/#${hex}${suffix}/g" "$tmp" > "$tmp2"
      mv "$tmp2" "$tmp"
    done
  done < <(awk -F '\t' '$0 !~ /^#/ && NF >= 2 { print $1 "\t" $2 "\t" $3 }' "$THEMES_FILE")
  cat "$tmp" > "$ZED_THEME_FILE"
  rm -f "$tmp"
}

rewrite_fuzzel_color() {
  local hex=$1 tmp
  [[ -f "$FUZZEL_CONF" ]] || return 0
  tmp=$(mktemp)
  awk -v accent="${hex}ff" '
    /^\[colors\]$/ { in_colors=1; print; next }
    /^\[/ { in_colors=0 }
    in_colors && /^(match|selection|border)=/ {
      sub(/=.*/, "=" accent)
    }
    { print }
  ' "$FUZZEL_CONF" > "$tmp"
  mv "$tmp" "$FUZZEL_CONF"
}

live_hypr_theme() {
  local hex=$1
  command -v hyprctl >/dev/null 2>&1 || return 0
  hyprctl keyword general:col.active_border "rgba(${hex}ff)" >/dev/null 2>&1 || true
  hyprctl keyword decoration:shadow:color "rgb(${hex})" >/dev/null 2>&1 || true
}

apply_theme() {
  local name=$1 mode=${2:-commit} line hex desc r g b
  line=$(theme_line "$name") || {
    printf 'unknown theme: %s\n' "$name" >&2
    exit 1
  }
  IFS=$'\t' read -r name hex desc <<< "$line"
  read -r r g b < <(hex_to_rgb "$hex")

  live_hypr_theme "$hex"

  mkdir -p "$THEMES_DIR"

  if [[ "$mode" != preview ]]; then
    cat > "$HYPR_THEME_FILE" <<THEME
# Generated by ~/.config/hypr/scripts/theme-picker
# Active theme: $name - $desc
\$theme_name = $name
\$theme_accent_hex = $hex
\$theme_accent_rgba = rgba(${hex}ff)
\$theme_accent_rgb = rgb(${hex})
THEME
  fi

  cat > "$WAYBAR_THEME_FILE" <<THEME
/* Generated by ~/.config/hypr/scripts/theme-picker */
/* ${mode^} theme: $name - $desc */
@define-color col_cyan #$hex;
THEME
  rewrite_waybar_style_color "$hex"
  rewrite_zed_theme_color "$hex"

  cat > "$SWAYOSD_THEME_FILE" <<THEME
/* Generated by ~/.config/hypr/scripts/theme-picker */
/* ${mode^} theme: $name - $desc */
@define-color osd_accent #$hex;
@define-color osd_accent_soft rgba($r, $g, $b, 0.45);
@define-color osd_accent_bar rgba($r, $g, $b, 0.95);
THEME

  if [[ "$mode" != preview ]]; then
    rewrite_fuzzel_color "$hex"
  fi
}

open_picker() {
  if [[ -f "$LOCK_FILE" ]]; then
    local old_pid
    old_pid=$(cat "$LOCK_FILE" 2>/dev/null || true)
    if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
      pkill -P "$old_pid" 2>/dev/null || true
      kill "$old_pid" 2>/dev/null || true
      rm -f "$LOCK_FILE"
      exit 0
    fi
    rm -f "$LOCK_FILE"
  fi

  [[ -x "$PREVIEW_PICKER" ]] || { printf 'missing native GTK theme picker: %s\n' "$PREVIEW_PICKER" >&2; exit 1; }

  echo $$ > "$LOCK_FILE"
  trap 'rm -f "$LOCK_FILE"' EXIT INT TERM
  "$PREVIEW_PICKER"
}

case "${1:-}" in
  --apply)
    [[ $# -eq 2 ]] || { usage; exit 2; }
    apply_theme "$2" commit
    ;;
  --preview)
    [[ $# -eq 2 ]] || { usage; exit 2; }
    apply_theme "$2" preview
    ;;
  --list)
    list_themes
    ;;
  "")
    open_picker
    ;;
  *)
    usage
    exit 2
    ;;
esac
