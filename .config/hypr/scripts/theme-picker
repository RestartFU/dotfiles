#!/usr/bin/env bash
set -euo pipefail
PATH="$HOME/.cargo/bin:$PATH"

THEMES_DIR="$HOME/.config/hyprland/themes"
THEMES_FILE="$THEMES_DIR/themes.tsv"
HYPR_THEME_FILE="$THEMES_DIR/hypr.conf"
WAYBAR_THEME_FILE="$THEMES_DIR/waybar.css"
SWAYOSD_THEME_FILE="$THEMES_DIR/swayosd.css"
NVIM_THEME_FILE="$THEMES_DIR/nvim.lua"
ALACRITTY_CONF="$HOME/.config/alacritty/alacritty.toml"
FUZZEL_CONF="$HOME/.config/fuzzel/fuzzel.ini"
ZED_THEME_FILE="$HOME/.config/zed/themes/dwm-hyprland.json"
HYPRLOCK_CONF="$HOME/.config/hypr/hyprlock.conf"
GTK3_SETTINGS="$HOME/.config/gtk-3.0/settings.ini"
GTK4_SETTINGS="$HOME/.config/gtk-4.0/settings.ini"
GTK3_CSS="$HOME/.config/gtk-3.0/gtk.css"
GTK4_CSS="$HOME/.config/gtk-4.0/gtk.css"
WAYPAPER_CONF="$HOME/.config/waypaper/config.ini"
LOCK_FILE="${XDG_RUNTIME_DIR:-/tmp}/hypr-theme-picker.pid"
PREVIEW_PICKER="$HOME/.config/hypr/scripts/theme-preview-picker"

usage() {
  printf 'usage: %s [--apply THEME|--preview THEME|--list]\n' "${0##*/}" >&2
}

theme_line() {
  local name=$1
  awk -F '\t' -v name="$name" '($0 !~ /^#/ && $1 == name) { print; found=1; exit } END { exit found ? 0 : 1 }' "$THEMES_FILE"
}

list_themes() {
  awk -F '\t' '$0 !~ /^#/ && NF >= 2 { printf "%-8s #%s  %s\n", $1, $2, $3 }' "$THEMES_FILE"
}

all_accents() {
  awk -F '\t' '$0 !~ /^#/ && NF >= 2 { print $2 }' "$THEMES_FILE"
}

hex_to_rgb() {
  local hex=$1
  printf '%d %d %d\n' "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

write_ini_setting() {
  local file=$1 section=$2 key=$3 value=$4 tmp
  mkdir -p "$(dirname "$file")"
  touch "$file"
  tmp=$(mktemp)
  awk -v section="$section" -v key="$key" -v value="$value" '
    BEGIN { in_section=0; seen_section=0; wrote=0 }
    $0 == "[" section "]" { in_section=1; seen_section=1; print; next }
    /^\[/ && in_section { if (!wrote) { print key "=" value; wrote=1 } in_section=0 }
    in_section && $0 ~ "^" key "=" { if (!wrote) { print key "=" value; wrote=1 } next }
    { print }
    END {
      if (!seen_section) { print "[" section "]"; print key "=" value }
      else if (in_section && !wrote) print key "=" value
    }
  ' "$file" > "$tmp"
  cat "$tmp" > "$file"
  rm -f "$tmp"
}

rewrite_waybar_style_color() {
  local accent=$1 bg=$2 fg=$3 tmp style="$HOME/.config/waybar/style.css"
  [[ -f "$style" ]] || return 0
  tmp=$(mktemp)
  awk -v accent="@define-color col_cyan #${accent};" \
      -v bg="@define-color col_gray1 #${bg};" \
      -v fg="@define-color col_gray4 #${fg};" '
    /^@define-color col_cyan / { print accent; cyan=1; next }
    /^@define-color col_gray1 / { print bg; gray1=1; next }
    /^@define-color col_gray4 / { print fg; gray4=1; next }
    { print }
    END { if (!gray1) print bg; if (!gray4) print fg; if (!cyan) print accent }
  ' "$style" > "$tmp"
  cat "$tmp" > "$style"
  rm -f "$tmp"
}

rewrite_file_known_accents() {
  local file=$1 hex=$2 tmp tmp2 old suffix
  [[ -f "$file" ]] || return 0
  tmp=$(mktemp)
  cp "$file" "$tmp"
  while read -r old; do
    [[ -n "${old:-}" ]] || continue
    for suffix in 88 66 ff ""; do
      tmp2=$(mktemp)
      sed "s/#${old}${suffix}/#${hex}${suffix}/g; s/${old}${suffix}/${hex}${suffix}/g" "$tmp" > "$tmp2"
      mv "$tmp2" "$tmp"
    done
  done < <(all_accents)
  cat "$tmp" > "$file"
  rm -f "$tmp"
}

rewrite_fuzzel_color() {
  local accent=$1 bg=$2 fg=$3 tmp
  [[ -f "$FUZZEL_CONF" ]] || return 0
  tmp=$(mktemp)
  awk -v accent="${accent}ff" -v bg="${bg}dd" -v fg="${fg}ff" '
    /^\[colors\]$/ { in_colors=1; print; next }
    /^\[/ { in_colors=0 }
    in_colors && /^background=/ { print "background=" bg; next }
    in_colors && /^text=/ { print "text=" fg; next }
    in_colors && /^(match|selection|border)=/ { sub(/=.*/, "=" accent) }
    { print }
  ' "$FUZZEL_CONF" > "$tmp"
  cat "$tmp" > "$FUZZEL_CONF"
  rm -f "$tmp"
}

rewrite_alacritty_theme() {
  local accent=$1 bg=$2 fg=$3 bright=$4 tmp
  [[ -f "$ALACRITTY_CONF" ]] || return 0
  tmp=$(mktemp)
  awk '
    /^# Generated by ~\/.config\/hypr\/scripts\/theme-picker$/ { next }
    /^\[colors(\.|\])/{ skip=1; next }
    /^\[/ { skip=0 }
    !skip { print }
  ' "$ALACRITTY_CONF" | awk '
    NF == 0 { blank++; if (blank <= 1) print; next }
    { blank=0; print }
  ' > "$tmp"
  cat >> "$tmp" <<THEME

# Generated by ~/.config/hypr/scripts/theme-picker
[colors.primary]
background = "#$bg"
foreground = "#$fg"

[colors.normal]
black = "#$bg"
red = "#cc5555"
green = "#55aa55"
yellow = "#aaaa55"
blue = "#$accent"
magenta = "#aa55aa"
cyan = "#00aaaa"
white = "#bbbbbb"

[colors.bright]
black = "#555555"
red = "#cc5555"
green = "#55aa55"
yellow = "#cccc55"
blue = "#$bright"
magenta = "#aa55aa"
cyan = "#33bbcc"
white = "#$fg"
THEME
  cat "$tmp" > "$ALACRITTY_CONF"
  rm -f "$tmp"
}

rewrite_gtk_theme() {
  local accent=$1 bg=$2 fg=$3
  mkdir -p "$(dirname "$GTK3_SETTINGS")" "$(dirname "$GTK4_SETTINGS")"
  write_ini_setting "$GTK3_SETTINGS" Settings gtk-application-prefer-dark-theme 1
  write_ini_setting "$GTK3_SETTINGS" Settings gtk-theme-name Adwaita-dark
  write_ini_setting "$GTK4_SETTINGS" Settings gtk-application-prefer-dark-theme 1
  write_ini_setting "$GTK4_SETTINGS" Settings gtk-theme-name Adwaita-dark
  for css in "$GTK3_CSS" "$GTK4_CSS"; do
    cat > "$css" <<THEME
/* Generated by ~/.config/hypr/scripts/theme-picker */
@define-color accent_color #$accent;
@define-color accent_bg_color #$accent;
@define-color accent_fg_color #$fg;
@define-color window_bg_color #$bg;
@define-color window_fg_color #$fg;
selection { background-color: #$accent; color: #$fg; }
*:selected { background-color: #$accent; color: #$fg; }
THEME
  done
  command -v gsettings >/dev/null 2>&1 && gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' >/dev/null 2>&1 || true
}

rewrite_hyprlock_theme() {
  local accent=$1 bg=$2 fg=$3 wallpaper=$4
  [[ -n "$wallpaper" && -f "$wallpaper" ]] || wallpaper=""
  cat > "$HYPRLOCK_CONF" <<THEME
# Generated by ~/.config/hypr/scripts/theme-picker
background {
    ${wallpaper:+path = $wallpaper}
    color = rgba(${bg}ff)
    blur_passes = 2
    blur_size = 4
}

label {
    text = \$TIME
    color = rgba(${fg}ff)
    font_size = 64
    position = 0, 100
    halign = center
    valign = center
}

label {
    text = $name
    color = rgba(${accent}ff)
    font_size = 16
    position = 0, 36
    halign = center
    valign = center
}

input-field {
    size = 220, 54
    outline_thickness = 3
    outer_color = rgba(${accent}ff)
    inner_color = rgba(${bg}dd)
    font_color = rgba(${fg}ff)
    check_color = rgba(${accent}ff)
    fail_color = rgba(cc5555ff)
    placeholder_text = <span foreground="#${fg}">password</span>
    position = 0, -100
    halign = center
    valign = center
}
THEME
}

rewrite_nvim_theme() {
  local accent=$1 bg=$2 fg=$3
  cat > "$NVIM_THEME_FILE" <<THEME
-- Generated by ~/.config/hypr/scripts/theme-picker
return {
  accent = "#$accent",
  bg = "#$bg",
  fg = "#$fg",
  gray2 = "#444444",
  gray3 = "#bbbbbb",
  red = "#cc5555",
  yellow = "#cccc55",
  green = "#55aa55",
}
THEME
}


is_powered() {
  local supply type scope online status
  for supply in /sys/class/power_supply/*; do
    [[ -r "$supply/type" ]] || continue
    type=$(<"$supply/type")
    scope=$([[ -r "$supply/scope" ]] && cat "$supply/scope" || true)
    online=$([[ -r "$supply/online" ]] && cat "$supply/online" || true)
    status=$([[ -r "$supply/status" ]] && cat "$supply/status" || true)
    case "$type" in
      Mains) [[ "$online" == 1 ]] && { printf '1\n'; return 0; } ;;
      USB|USB_C|USB_PD|Wireless) [[ "$scope" == System && ( "$online" == 1 || "$status" == Charging ) ]] && { printf '1\n'; return 0; } ;;
      Battery) [[ "$status" == Charging || "$status" == Full ]] && { printf '1\n'; return 0; } ;;
    esac
  done
  printf '0\n'
}

sync_wallpaper() {
  local wallpaper=$1 accent=$2 name=${3:-}
  if [[ -x "$HOME/.config/hypr/scripts/theme-wallpaper" && -n "$name" ]]; then
    "$HOME/.config/hypr/scripts/theme-wallpaper" auto "$name" >/dev/null 2>&1 || true
    return 0
  fi
  [[ -n "$wallpaper" && -f "$wallpaper" ]] || return 0
  if [[ -f "$WAYPAPER_CONF" ]]; then
    tmp=$(mktemp)
    awk -v wp="$wallpaper" '/^wallpaper = / { print "wallpaper = " wp; done=1; next } { print } END { if (!done) print "wallpaper = " wp }' "$WAYPAPER_CONF" > "$tmp"
    cat "$tmp" > "$WAYPAPER_CONF"
    rm -f "$tmp"
  fi
  if pgrep -xu "$USER" hyprpaper >/dev/null 2>&1; then
    hyprctl hyprpaper wallpaper ", $wallpaper, cover" >/dev/null 2>&1 || true
  elif command -v awww >/dev/null 2>&1; then
    mkdir -p "$HOME/.cache/awww"
    if ! pgrep -xu "$USER" awww-daemon >/dev/null 2>&1; then
      nohup awww-daemon >/tmp/awww-daemon.log 2>&1 &
      sleep 0.45
    fi
    awww img --all --resize crop --filter Nearest --transition-type none "$wallpaper" >/dev/null 2>&1 || awww clear --all "${accent}ff" >/dev/null 2>&1 || true
  fi
}
live_hypr_theme() {
  local hex=$1
  command -v hyprctl >/dev/null 2>&1 || return 0
  hyprctl --batch "keyword general:col.active_border rgba(${hex}ff); keyword decoration:shadow:color rgb(${hex})" >/dev/null 2>&1 || true
}

apply_theme() {
  local mode=${2:-commit} line name accent desc bg fg static_wallpaper plugged_wallpaper bright wallpaper r g b
  line=$(theme_line "$1") || {
    printf 'unknown theme: %s\n' "$1" >&2
    exit 1
  }
  IFS=$'\t' read -r name accent desc bg fg static_wallpaper plugged_wallpaper bright _ <<< "$line"
  bg=${bg:-222222}
  fg=${fg:-eeeeee}
  static_wallpaper=${static_wallpaper:-}
  plugged_wallpaper=${plugged_wallpaper:-$static_wallpaper}
  wallpaper=$([[ "$(is_powered)" == 1 ]] && printf %s "$plugged_wallpaper" || printf %s "$static_wallpaper")
  bright=${bright:-$accent}
  read -r r g b < <(hex_to_rgb "$accent")

  mkdir -p "$THEMES_DIR"
  live_hypr_theme "$accent"

  if [[ "$mode" != preview ]]; then
    cat > "$HYPR_THEME_FILE" <<THEME
# Generated by ~/.config/hypr/scripts/theme-picker
# Active theme: $name - $desc
\$theme_name = $name
\$theme_accent_hex = $accent
\$theme_accent_rgba = rgba(${accent}ff)
\$theme_accent_rgb = rgb(${accent})
\$theme_bg_hex = $bg
\$theme_fg_hex = $fg
\$theme_wallpaper = $wallpaper
\$theme_static_wallpaper = $static_wallpaper
\$theme_plugged_wallpaper = $plugged_wallpaper
THEME
  fi

  cat > "$WAYBAR_THEME_FILE" <<THEME
/* Generated by ~/.config/hypr/scripts/theme-picker */
/* ${mode^} theme: $name - $desc */
@define-color col_gray1 #$bg;
@define-color col_gray4 #$fg;
@define-color col_cyan #$accent;
THEME
  rewrite_waybar_style_color "$accent" "$bg" "$fg"

  cat > "$SWAYOSD_THEME_FILE" <<THEME
/* Generated by ~/.config/hypr/scripts/theme-picker */
/* ${mode^} theme: $name - $desc */
@define-color osd_accent #$accent;
@define-color osd_accent_soft rgba($r, $g, $b, 0.45);
@define-color osd_accent_bar rgba($r, $g, $b, 0.95);
THEME

  rewrite_file_known_accents "$ZED_THEME_FILE" "$accent"
  rewrite_fuzzel_color "$accent" "$bg" "$fg"
  rewrite_alacritty_theme "$accent" "$bg" "$fg" "$bright"
  rewrite_gtk_theme "$accent" "$bg" "$fg"
  rewrite_hyprlock_theme "$accent" "$bg" "$fg" "$wallpaper"
  rewrite_nvim_theme "$accent" "$bg" "$fg"

  sync_wallpaper "$wallpaper" "$accent" "$name"
}

open_picker() {
  if [[ -f "$LOCK_FILE" ]]; then
    local old_pid
    old_pid=$(cat "$LOCK_FILE" 2>/dev/null || true)
    if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
      pkill -P "$old_pid" 2>/dev/null || true
      kill "$old_pid" 2>/dev/null || true
      rm -f "$LOCK_FILE"
      exit 0
    fi
    rm -f "$LOCK_FILE"
  fi

  [[ -x "$PREVIEW_PICKER" ]] || { printf 'missing native GTK theme picker: %s\n' "$PREVIEW_PICKER" >&2; exit 1; }

  echo $$ > "$LOCK_FILE"
  trap 'rm -f "$LOCK_FILE"' EXIT INT TERM
  "$PREVIEW_PICKER"
}

case "${1:-}" in
  --apply)
    [[ $# -eq 2 ]] || { usage; exit 2; }
    apply_theme "$2" commit
    ;;
  --preview)
    [[ $# -eq 2 ]] || { usage; exit 2; }
    apply_theme "$2" preview
    ;;
  --list)
    list_themes
    ;;
  "")
    open_picker
    ;;
  *)
    usage
    exit 2
    ;;
esac
