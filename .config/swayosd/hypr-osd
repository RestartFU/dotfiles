#!/usr/bin/env bash
set -euo pipefail

CONFIG='/home/restart/.config/swayosd/config.toml'
STYLE='/home/restart/.config/swayosd/style.css'

ensure_swayosd() {
  command -v swayosd-server >/dev/null 2>&1 || return 1
  command -v swayosd-client >/dev/null 2>&1 || return 1
  if ! pgrep -xu "$USER" swayosd-server >/dev/null 2>&1; then
    nohup swayosd-server --config "$CONFIG" --style "$STYLE" >/tmp/swayosd.log 2>&1 &
    sleep 0.15
  fi
}

fallback_hypr_notify() {
  # Deliberately do not use Hyprland's built-in notify here: its default
  # white rectangle is exactly what this script replaced. If SwayOSD is
  # unavailable, change the setting silently rather than flashing that box.
  notify-send -t 800 "${1:-OSD}" "${2:-}" >/dev/null 2>&1 || true
}

run_swayosd() {
  if ensure_swayosd; then
    swayosd-client --config "$CONFIG" "$@" >/dev/null 2>&1 && return 0
  fi
  return 1
}

case "${1:-}" in
  volume-up)
    run_swayosd --output-volume +5 --max-volume 100 || { wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+; fallback_hypr_notify 'Volume'; }
    ;;
  volume-down)
    run_swayosd --output-volume -5 --max-volume 100 || { wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-; fallback_hypr_notify 'Volume'; }
    ;;
  volume-mute)
    run_swayosd --output-volume mute-toggle --max-volume 100 || { wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle; fallback_hypr_notify 'Volume' 'Muted'; }
    ;;
  mic-mute)
    run_swayosd --input-volume mute-toggle --max-volume 100 || { wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle; fallback_hypr_notify 'Microphone'; }
    ;;
  brightness-up)
    run_swayosd --brightness +5 --min-brightness 2 || { brightnessctl -e4 -n2 set 5%+ >/dev/null; fallback_hypr_notify 'Brightness'; }
    ;;
  brightness-down)
    run_swayosd --brightness -5 --min-brightness 2 || { brightnessctl -e4 -n2 set 5%- >/dev/null; fallback_hypr_notify 'Brightness'; }
    ;;
  show-volume)
    run_swayosd --custom-message 'Volume' --custom-icon audio-volume-high --custom-progress 0.5 --custom-progress-text 'mac-style OSD' || fallback_hypr_notify 'Volume'
    ;;
  show-brightness)
    run_swayosd --custom-message 'Brightness' --custom-icon display-brightness --custom-progress 0.7 --custom-progress-text 'mac-style OSD' || fallback_hypr_notify 'Brightness'
    ;;
  *)
    printf 'usage: %s {volume-up|volume-down|volume-mute|mic-mute|brightness-up|brightness-down|show-volume|show-brightness}\n' "$0" >&2
    exit 64
    ;;
esac
